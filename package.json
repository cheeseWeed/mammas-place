    "babel-plugin-react-compiler": "^19.1.0-rc.3",
    "d3-geo": "^3.1.1",
    "next": "16.1.6",
    "prisma": "^6.19.3",
    "puppeteer": "^24.37.5",
    "react": "19.2.3",
    "react-confetti": "^6.4.0",
    "react-dom": "19.2.3",
    "server-only": "^0.0.1",
    "topojson-client": "^3.1.0"
  },
