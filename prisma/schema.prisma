// Prisma schema for the Utah Driver License multi-user progress store.
// Backed by Neon Postgres in prod, can use a local Postgres in dev.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// One row per registered learner.
//
// Originally created for the Driver License study tool (hence the table name
// `drive_users` and the legacy Drive-specific JSON blobs at the top), but now
// acts as the shared LearnerProfile across every learning section in the app
// (Drive, Geography, Spelling, ...). New sections add a JSONB column for
// their per-user progress; profile fields (age, grade, displayName) sit at
// the row level so all sections can read/write them through one place.
//
// Bulk fields stay as JSONB for simplicity — small data per user (under a
// few KB each), no need to normalize.
model DriveUser {
  name             String   @id // normalized lowercase username
  pinHash          String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // ----- Drive (Utah Driver License study) -----
  attempts         Json     @default("[]") // QuizAttempt[]
  misses           Json     @default("[]") // string[]
  unitScores       Json     @default("{}") // Record<string, UnitScore>
  sr               Json     @default("{}") // Record<string, SrRecord>
  mode             String?  // 'quick' | 'deep' | null
  deckCompletions  Json     @default("{}") // Record<string, number>

  // ----- Shared learner profile (all sections) -----
  ageYears         Int?     // optional — collected at registration or settings
  gradeLevel       String?  // "preschool" | "K" | "1".."12"
  displayName      String?  // pretty-cased name for UI; falls back to `name`

  // ----- Family / chores (Family Chores section) -----
  // `isParent` is granted by the app Admin. A parent can create/edit their
  // family's chore chart, invite members, take points, and see the redeem log.
  // `familyId` is the family this user belongs to (parent or member). Null = not
  // in a family yet. A family can have multiple parents (mom AND dad). See
  // app/chores/PLAN.md + lib/family/.
  isParent         Boolean  @default(false)
  familyId         String?
  family           Family?  @relation(fields: [familyId], references: [id])

  // ----- Per-section progress blobs -----
  // Spelling: { level: number, attempts: SpellingAttempt[], misses: string[], lastSession?: number, ... }
  spelling         Json     @default("{}")
  // Geography: { phases: Record<string, unknown>, lastActive?: number, ... }
  // Currently opt-in — Geography defaults to anonymous localStorage.
  geography        Json     @default("{}")
  // Math: { roundsPlayed: number, bestStreak: number, lastSession?: number, history: MathRound[], ... }
  math             Json     @default("{}")
  // Language Arts: { homophones: {...}, grammar: {...}, ..., lastSession?: number }
  languageArts     Json     @default("{}")
  // Chess: { current?: SavedChessGame, recentGames: SavedChessGame[], totals: {...}, ... }
  // Shape defined in lib/chess/game-state.ts (ChessProgress).
  chess            Json     @default("{}")
  // Music: practice tracker for any instrument. Shape (MusicProfile) defined
  // in lib/music/types.ts: { pieces: MusicPiece[], challenge?: MusicChallenge }.
  // Each piece carries its title/instrument/estLines/targetDate, a per-day
  // log of quality scores (1-10), and a passedOffAt stamp once mastered.
  // Daily practice earns MP through /api/music/practice (own earn path, like
  // chess games) but still writes section='music' MpEarning rows so the
  // wallet grid totals it. See app/music/PLAN.md.
  music            Json     @default("{}")
  // Audiobook listen history keyed by product id.
  // Shape: Record<productId, { lastListenedAt: number, completed: boolean }>
  // See lib/audiobooks.ts for read/write helpers.
  audioHistory     Json     @default("{}")
  // "Up next" pointer per series — Record<series, productId> of the next
  // un-completed item in that series. Updated by markListenComplete when an
  // episode finishes; lets the homepage build "Continue listening" without
  // scanning every audiobook.
  seriesProgress   Json     @default("{}")

  // ----- MP Money (closed-loop family economy) -----
  // Balance kept in cents to avoid float drift. See app/money/PLAN.md.
  balanceCents     Int      @default(0)
  // Phase 6a: MP account card. Short 4-digit suffix unique per kid, used as a
  // receive-only identifier (grandparents can credit it, but spending still
  // requires the kid's PIN). Null until first issued. See PLAN-Phase6-Cards.md.
  mpCardNumber     String?  @unique
  mpCardCreatedAt  DateTime?
  transactions     MpTransaction[]
  orders           MpOrder[]
  earnings         MpEarning[]
  dadAsks          DadAsk[]

  @@map("drive_users")
}

// Append-only ledger. Every credit/debit is a row; balance on DriveUser is the
// running total. Never mutate; reversals create a new row with negated cents.
model MpTransaction {
  id        String   @id @default(cuid())
  userName  String
  user      DriveUser @relation(fields: [userName], references: [name], onDelete: Cascade)
  cents     Int      // positive = credit, negative = debit
  type      String   // 'earn' | 'spend' | 'gift' | 'refund' | 'adjust'
  reason    String
  orderId   String?
  createdAt DateTime @default(now())

  @@index([userName, createdAt])
  @@map("mp_transactions")
}

// Closed-loop "order" — no shipping, no payment processor. items is a snapshot
// of the cart at purchase time so price changes don't rewrite history.
model MpOrder {
  id          String   @id @default(cuid())
  userName    String
  user        DriveUser @relation(fields: [userName], references: [name], onDelete: Cascade)
  items       Json     // [{ productId, name, qty, priceCents }]
  totalCents  Int
  status      String   @default("fulfilled") // 'fulfilled' | 'cancelled' | 'pending'
  createdAt   DateTime @default(now())

  @@index([userName, createdAt])
  @@map("mp_orders")
}

// Kid-earned MP from learning sections. Idempotency key prevents the same
// round/quiz from crediting twice on accidental re-submit. `cents` is what
// the server computed (kid client cannot dictate it).
model MpEarning {
  id           String   @id @default(cuid())
  userName     String
  user         DriveUser @relation(fields: [userName], references: [name], onDelete: Cascade)
  section      String   // 'math' | 'languageArts' | 'spelling' | 'geography' | 'drive' | 'chess' | 'music'
  kind         String   // section-defined: e.g. 'math.round', 'spelling.quiz', 'drive.deck', 'music.practice'
  cents        Int      // always positive
  idempotencyKey String @unique
  meta         Json?    // {score, total, streak, ...} for debugging
  createdAt    DateTime @default(now())

  @@index([userName, createdAt])
  @@index([userName, section])
  @@map("mp_earnings")
}

// Singleton row holding the parent's admin PIN (hashed). First /api/money/parent/setup
// POST seeds it; after that, currentPin required to change.
model ParentConfig {
  id            Int      @id @default(1)
  parentPinHash String
  updatedAt     DateTime @updatedAt

  @@map("mp_parent_config")
}

// "Ask Dad" — automated server-side Dad persona. Kid asks for MP with a reason;
// server scores reason quality + ask cadence + amount and rolls a weighted die
// to pick an outcome bucket. Reply text is picked from a per-bucket bank in
// lib/money/dad.ts. Not a real human — no admin queue, no parent approval.
model DadAsk {
  id            String   @id @default(cuid())
  userName      String
  user          DriveUser @relation(fields: [userName], references: [name], onDelete: Cascade)
  centsAsked    Int
  reason        String
  outcome       String   // 'yes_full' | 'yes_partial' | 'pickup_tab' | 'maybe_later' | 'no' | 'bad_luck'
  centsGranted  Int      @default(0)
  dadReply      String
  context       String   @default("portal") // 'portal' | 'checkout'
  createdAt     DateTime @default(now())

  @@index([userName, createdAt])
  @@map("mp_dad_asks")
}

// Admin-editable product catalog. Originally lived as a static JSON file
// (data/products.json) shipped at build time; promoted to the DB so the
// MP Bank admin dashboard can edit products without a redeploy.
//
// Field shape mirrors lib/types.Product. `priceCents` and `originalPriceCents`
// are stored as integers to avoid float drift (same pattern as MP balances).
// JSON columns hold the loosely-typed arrays (tags, images, reviews).
model Product {
  id                  String   @id // matches the legacy string ids ("pony-001", etc.)
  name                String
  priceCents          Int
  originalPriceCents  Int?     // null = no strikethrough
  discount            Int      @default(0) // percentage, 0..100
  description         String
  shortDescription    String
  category            String
  subcategory         String?
  tags                Json     @default("[]")   // string[]
  imageUrl            String
  images              Json     @default("[]")   // string[]
  inStock             Boolean  @default(true)
  stockCount          Int      @default(0)
  rating              Float    @default(0)
  reviewCount         Int      @default(0)
  isSale              Boolean  @default(false)
  isFeatured          Boolean  @default(false)
  isComingSoon        Boolean  @default(false)
  availableOnWebsite  Boolean  @default(true)
  sku                 String   @unique
  audioPreviewUrl     String?
  isAudiobook         Boolean  @default(false)
  isStudyGuide        Boolean  @default(false)
  studyGuideUrl       String?
  downloadUrl         String?
  reviews             Json?    // Review[] | null
  // Audiobook series grouping (lib/audiobooks.ts). Null for non-audiobook
  // items. Each standalone audiobook gets its own single-item series so the
  // "up next" lookup always has a key. Episode number lives in the JSON
  // catalog only (data/products.json) for now — it's only used as a tie-break
  // when ordering items within a series, derivable from SKU if absent.
  series              String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // ----- Inventory rotation (lib/inventory.ts) -----
  // Owned by the inventory subsystem. Additive — products-tab agent should
  // leave these alone. All optional/nullable so existing seed/POST flows
  // don't need to set them; null = "behave like the old static catalog".
  //
  // null = unlimited stock (the default for legacy items). Otherwise current
  // on-hand count. decrementStock() enforces non-negative.
  stockQuantity       Int?
  // Availability window. Shape:
  //   { type: 'always' | 'weekly' | 'monthly' | 'dated',
  //     daysOfWeek?: number[],       // 0=Sun..6=Sat, for 'weekly'
  //     weekOfMonth?: number[],      // 1..5, for 'monthly'
  //     featuredDates?: string[] }   // ["MM-DD", ...] — pins to that calendar day
  // Audiobooks and study guides ignore this and are always available
  // (server-enforced in lib/inventory.ts).
  availabilityRule    Json?
  // Auto-restock cadence. Shape:
  //   { cadence: 'mon-thu' | 'weekly' | 'never', amount: number }
  // null = no auto-restock. Hit POST /api/inventory/restock to apply.
  restockSchedule     Json?
  // Stamp from the last successful restock; prevents double-restock on a
  // single calendar day even if the cron runs twice.
  lastRestockAt       DateTime?

  @@index([category])
  @@index([isFeatured])
  @@index([isSale])
  @@map("products")
}

// Kid-submitted feedback. Public POST (rate-limited), parent-gated GET/PUT.
// `page` records the URL the kid was on when they sent it; helpful context
// when triaging ("they hit submit from /shop/checkout").
model Feedback {
  id          String   @id @default(cuid())
  authorName  String?
  // The logged-in user (dl_user) who sent it — stamped ONLY when they provided
  // a name. Blank name = fully anonymous, no identity attached, no reply thread.
  authorUser  String?
  body        String
  page        String?
  userAgent   String?
  status      String   @default("new") // 'new' | 'read' | 'archived'
  // Admin's reply + when it was sent. Null until the admin answers.
  reply       String?
  repliedAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([status, createdAt])
  @@index([authorUser, createdAt])
  @@map("feedback")
}

// Phase 6c — Printable single-use gift cards. Parents mint codes like
// `MP-7K2H9N`, print them, and hand them to a kid for birthdays / surprises.
// One redemption flips the card from unredeemed → redeemed and credits the
// kid via the existing balance.ts `credit()` helper (no second economy).
//
// `code` is the public string shown to humans (including the `MP-` prefix);
// kept as a separate column (not the PK) so we can hold a synthetic cuid id
// for joins later if we ever add per-card audit detail.
model MpGiftCard {
  id             String    @id @default(cuid())
  code           String    @unique // "MP-XXXXXX", 6-char base32 alphabet (no 0/O/1/I/L)
  cents          Int
  createdAt      DateTime  @default(now())
  redeemedByName String?
  redeemedAt     DateTime?
  revoked        Boolean   @default(false)
  note           String?   // parent's optional note ("Happy birthday!")

  @@map("mp_gift_cards")
}

// A family unit — owned by one or more parents (mom AND dad), with invited
// members. Owns its own chore chart. Multi-tenant: different families build
// and edit their own charts, fully isolated. See app/chores/PLAN.md.
//
// `jobs` is the chore catalog for THIS family as a JSON array (FamilyJob[],
// shape in lib/family/types.ts) — same blob pattern as music pieces. Each job
// carries room / frequency / MP / optional assignee / completion history.
//
// `redemptions` is the append-only log of external MP redemptions kids made
// ("movie night – 200MP"), each already debited. Parents read it; no approval.
model Family {
  id          String   @id @default(cuid())
  name        String   // "The Glazier Family"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  // Usernames of the parents who manage this family (normalized lowercase).
  // Mirrors DriveUser.isParent — a user must be flagged isParent by Admin AND
  // listed here to manage. Stored as JSON string[] for simple multi-parent.
  parents     Json     @default("[]")
  // The chore catalog (FamilyJob[]). See lib/family/types.ts.
  jobs        Json     @default("[]")
  members     DriveUser[]

  @@map("families")
}

// A kid-filed "I forgot my PIN" request. Non-destructive: filing one NEVER
// touches the account or its progress. The admin sees pending requests on the
// MP Bank dashboard and sets a new PIN; that flips status to 'resolved'. The
// kid then logs in with the PIN the admin gave them and can change it from the
// "Change PIN" spot on the login screen. Replaces the old destructive
// "type reset to wipe" flow.
model PinResetRequest {
  id          String    @id @default(cuid())
  userName    String    // who asked (normalized lowercase) — NOT a FK so a
                        // request survives even if the user row is absent
  status      String    @default("pending") // 'pending' | 'resolved' | 'dismissed'
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?

  @@index([status, createdAt])
  @@map("pin_reset_requests")
}

// Two-device chess match — a shared game row two kids play across separate
// devices/browsers (no websockets/Bluetooth). One creator (white) makes a
// match and gets a short join `code`; the second kid joins as black. The row
// is the single source of truth: each device polls GET to pick up the other's
// moves and POSTs its own via the engine-validated /move endpoint. The server
// re-validates EVERY move with lib/chess/engine — clients are never trusted for
// legality. `version` bumps on each accepted move so a poller can cheaply tell
// "something changed" and skip re-deriving when it hasn't.
//
// MP rewards are intentionally NOT wired for 2-device games yet (would need
// careful per-side attribution to avoid double-credit). See app/chess/play
// PlayMatch + /api/chess/match/[code]/move TODOs.
model ChessMatch {
  id          String   @id @default(cuid())
  code        String   @unique // short readable join code, e.g. "RACE" (no 0/O/1/I/L)
  whiteUser   String?  // creator (normalized dl_user)
  blackUser   String?  // joiner (normalized dl_user)
  moveHistory Json     @default("[]") // string[] of UCI ("e2e4", "e7e8q")
  fen         String   @default("rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 0 1")
  theme       String   @default("classic")
  status      String   @default("waiting") // 'waiting' | 'active' | 'finished'
  turn        String   @default("w")       // 'w' | 'b' — whose move it is
  version     Int      @default(0)         // bumps each accepted move
  result      Json?    // { winner: 'w'|'b'|'draw', reason, finalFen } when finished
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
  @@map("chess_matches")
}

// Append-only redemption log. A kid redeems MP for an external reward; we debit
// immediately (via balance.ts debit) and write one row here so parents can SEE
// what was spent. No approval gate — the real-world OK happens in person.
model Redemption {
  id          String   @id @default(cuid())
  familyId    String
  userName    String   // who redeemed (normalized)
  cents       Int      // amount debited (positive)
  reward      String   // free-form: "Movie night", "$5 cash", ...
  funMessage  String   // the "Have fun!" / "Break a leg!" line shown
  createdAt   DateTime @default(now())

  @@index([familyId, createdAt])
  @@index([userName, createdAt])
  @@map("redemptions")
}
