// Prisma schema for the Utah Driver License multi-user progress store.
// Backed by Neon Postgres in prod, can use a local Postgres in dev.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// One row per registered learner.
//
// Originally created for the Driver License study tool (hence the table name
// `drive_users` and the legacy Drive-specific JSON blobs at the top), but now
// acts as the shared LearnerProfile across every learning section in the app
// (Drive, Geography, Spelling, ...). New sections add a JSONB column for
// their per-user progress; profile fields (age, grade, displayName) sit at
// the row level so all sections can read/write them through one place.
//
// Bulk fields stay as JSONB for simplicity — small data per user (under a
// few KB each), no need to normalize.
model DriveUser {
  name             String   @id // normalized lowercase username
  pinHash          String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // ----- Drive (Utah Driver License study) -----
  attempts         Json     @default("[]") // QuizAttempt[]
  misses           Json     @default("[]") // string[]
  unitScores       Json     @default("{}") // Record<string, UnitScore>
  sr               Json     @default("{}") // Record<string, SrRecord>
  mode             String?  // 'quick' | 'deep' | null
  deckCompletions  Json     @default("{}") // Record<string, number>

  // ----- Shared learner profile (all sections) -----
  ageYears         Int?     // optional — collected at registration or settings
  gradeLevel       String?  // "preschool" | "K" | "1".."12"
  displayName      String?  // pretty-cased name for UI; falls back to `name`

  // ----- Per-section progress blobs -----
  // Spelling: { level: number, attempts: SpellingAttempt[], misses: string[], lastSession?: number, ... }
  spelling         Json     @default("{}")
  // Geography: { phases: Record<string, unknown>, lastActive?: number, ... }
  // Currently opt-in — Geography defaults to anonymous localStorage.
  geography        Json     @default("{}")
  // Math: { roundsPlayed: number, bestStreak: number, lastSession?: number, history: MathRound[], ... }
  math             Json     @default("{}")
  // Language Arts: { homophones: {...}, grammar: {...}, ..., lastSession?: number }
  languageArts     Json     @default("{}")
  // Chess: { current?: SavedChessGame, recentGames: SavedChessGame[], totals: {...}, ... }
  // Shape defined in lib/chess/game-state.ts (ChessProgress).
  chess            Json     @default("{}")

  // ----- MP Money (closed-loop family economy) -----
  // Balance kept in cents to avoid float drift. See app/money/PLAN.md.
  balanceCents     Int      @default(0)
  transactions     MpTransaction[]
  orders           MpOrder[]
  earnings         MpEarning[]

  @@map("drive_users")
}

// Append-only ledger. Every credit/debit is a row; balance on DriveUser is the
// running total. Never mutate; reversals create a new row with negated cents.
model MpTransaction {
  id        String   @id @default(cuid())
  userName  String
  user      DriveUser @relation(fields: [userName], references: [name], onDelete: Cascade)
  cents     Int      // positive = credit, negative = debit
  type      String   // 'earn' | 'spend' | 'gift' | 'refund' | 'adjust'
  reason    String
  orderId   String?
  createdAt DateTime @default(now())

  @@index([userName, createdAt])
  @@map("mp_transactions")
}

// Closed-loop "order" — no shipping, no payment processor. items is a snapshot
// of the cart at purchase time so price changes don't rewrite history.
model MpOrder {
  id          String   @id @default(cuid())
  userName    String
  user        DriveUser @relation(fields: [userName], references: [name], onDelete: Cascade)
  items       Json     // [{ productId, name, qty, priceCents }]
  totalCents  Int
  status      String   @default("fulfilled") // 'fulfilled' | 'cancelled' | 'pending'
  createdAt   DateTime @default(now())

  @@index([userName, createdAt])
  @@map("mp_orders")
}

// Kid-earned MP from learning sections. Idempotency key prevents the same
// round/quiz from crediting twice on accidental re-submit. `cents` is what
// the server computed (kid client cannot dictate it).
model MpEarning {
  id           String   @id @default(cuid())
  userName     String
  user         DriveUser @relation(fields: [userName], references: [name], onDelete: Cascade)
  section      String   // 'math' | 'languageArts' | 'spelling' | 'geography' | 'drive'
  kind         String   // section-defined: e.g. 'math.round', 'spelling.quiz', 'drive.deck'
  cents        Int      // always positive
  idempotencyKey String @unique
  meta         Json?    // {score, total, streak, ...} for debugging
  createdAt    DateTime @default(now())

  @@index([userName, createdAt])
  @@index([userName, section])
  @@map("mp_earnings")
}

// Singleton row holding the parent's admin PIN (hashed). First /api/money/parent/setup
// POST seeds it; after that, currentPin required to change.
model ParentConfig {
  id            Int      @id @default(1)
  parentPinHash String
  updatedAt     DateTime @updatedAt

  @@map("mp_parent_config")
}
