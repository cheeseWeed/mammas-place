# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude/serena/playwright
.claude/
.serena/
.playwright-mcp/

# screenshots and demo docs
*.png
!public/images/*.png
*-experience.md
*-transcript.md
demo-warnings*.md
warning-locations.md

# grok session data (contains auth cookies — never commit)
grok_session.json
grok_session_data/

# failed SVG experiments
public/images/banana.svg
public/images/paint-horse.svg
public/images/pig.svg
public/images/squirrel-horse.svg

# Windows reserved filename
nul
